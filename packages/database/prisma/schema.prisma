generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole       { BUYER SELLER AGENT ADMIN }
enum KycStatus      { PENDING SUBMITTED VERIFIED REJECTED EXPIRED }
enum PropertyType   { HOUSE APARTMENT LAND COMMERCIAL VILLA COMPOUND }
enum PropertyStatus { DRAFT PENDING_REVIEW ACTIVE UNDER_OFFER SOLD WITHDRAWN SUSPENDED }
enum ListingCurrency{ GMD USD GBP EUR }
enum EscrowStatus   { INITIATED FUNDED INSPECTING APPROVED DISPUTED RELEASED REFUNDED CANCELLED }
enum TransactionType{ DEPOSIT FULL_PAYMENT INSTALLMENT FEE REFUND RELEASE }
enum TransactionStatus { PENDING PROCESSING COMPLETED FAILED REVERSED }
enum DocumentType   { TITLE_DEED SURVEY_PLAN BUILDING_PERMIT PURCHASE_AGREEMENT POWER_OF_ATTORNEY IDENTITY_DOCUMENT PROOF_OF_FUNDS INSPECTION_REPORT TAX_CLEARANCE OTHER }
enum DocumentStatus { PENDING UPLOADED VERIFIED REJECTED EXPIRED }
enum NotificationType { EMAIL SMS PUSH IN_APP }
enum NotificationStatus { PENDING SENT DELIVERED FAILED READ }
enum OfferStatus    { PENDING ACCEPTED REJECTED COUNTERED EXPIRED WITHDRAWN }
enum InspectionStatus { SCHEDULED IN_PROGRESS COMPLETED CANCELLED }

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  phone             String?         @unique
  passwordHash      String
  role              UserRole        @default(BUYER)
  isEmailVerified   Boolean         @default(false)
  isPhoneVerified   Boolean         @default(false)
  isActive          Boolean         @default(true)
  isSuspended       Boolean         @default(false)
  diasporaCountry   String?
  preferredCurrency ListingCurrency @default(USD)
  stripeCustomerId  String?
  stripeAccountId   String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  profile           UserProfile?
  kyc               KycRecord?
  sessions          Session[]
  listings          Listing[]
  offersAsBuyer     Offer[]          @relation("BuyerOffers")
  escrowsAsBuyer    EscrowAccount[]  @relation("BuyerEscrows")
  escrowsAsSeller   EscrowAccount[]  @relation("SellerEscrows")
  documents         Document[]
  notifications     Notification[]
  savedListings     SavedListing[]
  reviews           Review[]         @relation("ReviewAuthor")
  receivedReviews   Review[]         @relation("ReviewSubject")
  @@map("users")
}

model UserProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  firstName   String
  lastName    String
  avatarUrl   String?
  bio         String?
  nationality String?
  address     String?
  city        String?
  country     String?
  dateOfBirth DateTime?
  languages   String[]
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("user_profiles")
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  refreshToken String    @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("sessions")
}

model KycRecord {
  id              String    @id @default(cuid())
  userId          String    @unique
  status          KycStatus @default(PENDING)
  smileJobId      String?
  idType          String?
  idNumber        String?
  idCountry       String?
  idExpiryDate    DateTime?
  selfieImageUrl  String?
  idFrontUrl      String?
  idBackUrl       String?
  verifiedAt      DateTime?
  rejectionReason String?
  rawResponse     Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("kyc_records")
}

model Listing {
  id                  String          @id @default(cuid())
  sellerId            String
  title               String
  slug                String          @unique
  description         String
  propertyType        PropertyType
  status              PropertyStatus  @default(DRAFT)
  price               Decimal         @db.Decimal(15,2)
  currency            ListingCurrency @default(GMD)
  priceUsd            Decimal?        @db.Decimal(15,2)
  isNegotiable        Boolean         @default(false)
  isInstallment       Boolean         @default(false)
  installmentYears    Int?
  address             String
  region              String
  area                String?
  latitude            Decimal?        @db.Decimal(10,7)
  longitude           Decimal?        @db.Decimal(10,7)
  bedrooms            Int?
  bathrooms           Int?
  toilets             Int?
  landSizesqm         Decimal?        @db.Decimal(10,2)
  buildingSizesqm     Decimal?        @db.Decimal(10,2)
  yearBuilt           Int?
  floors              Int?
  features            String[]
  furnished           Boolean         @default(false)
  hasElectricity      Boolean         @default(true)
  hasWater            Boolean         @default(true)
  hasInternet         Boolean         @default(false)
  hasSecurity         Boolean         @default(false)
  titleDeedAvailable  Boolean         @default(false)
  titleDeedNumber     String?
  viewCount           Int             @default(0)
  savedCount          Int             @default(0)
  aiSummary           String?
  diasporaHighlights  String[]
  publishedAt         DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  seller              User            @relation(fields: [sellerId], references: [id])
  images              ListingImage[]
  videos              ListingVideo[]
  offers              Offer[]
  escrows             EscrowAccount[]
  documents           Document[]
  savedBy             SavedListing[]
  inspections         Inspection[]
  priceHistory        PriceHistory[]
  @@index([sellerId])
  @@index([status])
  @@index([region])
  @@index([propertyType])
  @@map("listings")
}

model ListingImage {
  id           String   @id @default(cuid())
  listingId    String
  cloudinaryId String
  url          String
  thumbnailUrl String?
  caption      String?
  isPrimary    Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  @@index([listingId])
  @@map("listing_images")
}

model ListingVideo {
  id           String   @id @default(cuid())
  listingId    String
  cloudinaryId String?
  url          String
  thumbnailUrl String?
  title        String?
  duration     Int?
  createdAt    DateTime @default(now())
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  @@index([listingId])
  @@map("listing_videos")
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  @@unique([userId, listingId])
  @@map("saved_listings")
}

model PriceHistory {
  id        String          @id @default(cuid())
  listingId String
  price     Decimal         @db.Decimal(15,2)
  currency  ListingCurrency
  reason    String?
  changedAt DateTime        @default(now())
  listing   Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  @@index([listingId])
  @@map("price_history")
}

model Offer {
  id            String      @id @default(cuid())
  listingId     String
  buyerId       String
  amount        Decimal     @db.Decimal(15,2)
  currency      ListingCurrency
  status        OfferStatus @default(PENDING)
  message       String?
  counterAmount Decimal?    @db.Decimal(15,2)
  counterMessage String?
  expiresAt     DateTime
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  listing       Listing     @relation(fields: [listingId], references: [id])
  buyer         User        @relation("BuyerOffers", fields: [buyerId], references: [id])
  escrow        EscrowAccount?
  @@index([listingId])
  @@index([buyerId])
  @@map("offers")
}

model EscrowAccount {
  id                    String          @id @default(cuid())
  referenceNumber       String          @unique @default(cuid())
  listingId             String
  offerId               String?         @unique
  buyerId               String
  sellerId              String
  totalAmount           Decimal         @db.Decimal(15,2)
  currency              ListingCurrency
  status                EscrowStatus    @default(INITIATED)
  stripePaymentIntentId String?
  stripeTransferId      String?
  platformFeePercent    Decimal         @default(2.5) @db.Decimal(5,2)
  platformFeeAmount     Decimal?        @db.Decimal(15,2)
  sellerPayoutAmount    Decimal?        @db.Decimal(15,2)
  inspectionDays        Int             @default(14)
  inspectionDeadline    DateTime?
  fundedAt              DateTime?
  releasedAt            DateTime?
  refundedAt            DateTime?
  cancelledAt           DateTime?
  disputeReason         String?
  releaseNotes          String?
  adminNotes            String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  listing               Listing         @relation(fields: [listingId], references: [id])
  offer                 Offer?          @relation(fields: [offerId], references: [id])
  buyer                 User            @relation("BuyerEscrows", fields: [buyerId], references: [id])
  seller                User            @relation("SellerEscrows", fields: [sellerId], references: [id])
  milestones            EscrowMilestone[]
  transactions          Transaction[]
  inspections           Inspection[]
  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@map("escrow_accounts")
}

model EscrowMilestone {
  id          String    @id @default(cuid())
  escrowId    String
  title       String
  description String?
  amount      Decimal   @db.Decimal(15,2)
  dueDate     DateTime?
  completedAt DateTime?
  order       Int
  escrow      EscrowAccount @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  @@index([escrowId])
  @@map("escrow_milestones")
}

model Transaction {
  id                    String            @id @default(cuid())
  escrowId              String
  type                  TransactionType
  status                TransactionStatus @default(PENDING)
  amount                Decimal           @db.Decimal(15,2)
  currency              ListingCurrency
  stripePaymentIntentId String?
  stripeChargeId        String?
  metadata              Json?
  processedAt           DateTime?
  failureReason         String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  escrow                EscrowAccount     @relation(fields: [escrowId], references: [id])
  @@index([escrowId])
  @@map("transactions")
}

model Document {
  id              String         @id @default(cuid())
  uploadedById    String
  listingId       String?
  type            DocumentType
  status          DocumentStatus @default(PENDING)
  title           String
  description     String?
  cloudinaryId    String?
  url             String?
  encryptedUrl    String?
  fileSize        Int?
  mimeType        String?
  isPublic        Boolean        @default(false)
  verifiedAt      DateTime?
  verifiedById    String?
  expiryDate      DateTime?
  rejectionReason String?
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  uploadedBy      User           @relation(fields: [uploadedById], references: [id])
  listing         Listing?       @relation(fields: [listingId], references: [id])
  @@index([uploadedById])
  @@index([listingId])
  @@map("documents")
}

model Inspection {
  id                  String           @id @default(cuid())
  listingId           String
  escrowId            String?
  inspectorName       String
  inspectorEmail      String
  inspectorPhone      String?
  status              InspectionStatus @default(SCHEDULED)
  scheduledDate       DateTime
  completedAt         DateTime?
  reportUrl           String?
  findings            String?
  overallCondition    String?
  recommendations     String[]
  estimatedRepairCost Decimal?         @db.Decimal(12,2)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  listing             Listing          @relation(fields: [listingId], references: [id])
  escrow              EscrowAccount?   @relation(fields: [escrowId], references: [id])
  @@index([listingId])
  @@map("inspections")
}

model Notification {
  id            String             @id @default(cuid())
  userId        String
  type          NotificationType
  status        NotificationStatus @default(PENDING)
  title         String
  body          String
  data          Json?
  templateId    String?
  externalId    String?
  readAt        DateTime?
  sentAt        DateTime?
  failureReason String?
  createdAt     DateTime           @default(now())
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("notifications")
}

model Review {
  id         String   @id @default(cuid())
  authorId   String
  subjectId  String
  listingId  String?
  rating     Int
  title      String?
  body       String
  isVerified Boolean  @default(false)
  isPublic   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation("ReviewAuthor",  fields: [authorId],  references: [id])
  subject    User     @relation("ReviewSubject", fields: [subjectId], references: [id])
  @@unique([authorId, subjectId, listingId])
  @@map("reviews")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(15,6)
  source       String   @default("manual")
  updatedAt    DateTime @updatedAt
  @@unique([fromCurrency, toCurrency])
  @@map("exchange_rates")
}
