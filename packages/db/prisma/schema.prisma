generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BUYER
  AGENT
  ADMIN
}

enum KYCStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum KYCCheckResult {
  NOT_STARTED
  PENDING
  PASSED
  REVIEW_REQUIRED
  FAILED
}

enum PropertyType {
  HOUSE
  LAND
  APARTMENT
  COMMERCIAL
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  SOLD
}

enum EscrowStatus {
  INITIATED
  FUNDED
  TITLE_VERIFIED
  DOCS_SIGNED
  COMPLETED
  DISPUTED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  WAVE
  ORANGE_MONEY
}

enum PaymentMethod {
  CARD
  MOBILE_MONEY
}

enum PaymentStatus {
  NOT_STARTED
  PENDING
  REQUIRES_ACTION
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELED
}

enum EnquiryStatus {
  SENT
  REPLIED
  CLOSED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  fullName      String
  phone         String?
  country       String?
  role          Role       @default(BUYER)
  kycStatus     KYCStatus  @default(PENDING)
  emailVerified Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  sessions      Session[]
  listings      Listing[]
  enquiries     Enquiry[]
  savedListings SavedListing[]
  escrows       EscrowTransaction[]
  kycRecord     KYCRecord?

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model KYCRecord {
  id                  String         @id @default(cuid())
  userId              String         @unique
  documentType        String
  documentNumber      String?
  issuingCountry      String?
  documentUrl         String?
  documentBackUrl     String?
  selfieUrl           String?
  smileJobId          String?
  amlReferenceId      String?
  provider            String         @default("SMILE_IDENTITY")
  status              KYCStatus      @default(SUBMITTED)
  documentCheckStatus KYCCheckResult @default(PENDING)
  livenessStatus      KYCCheckResult @default(PENDING)
  amlStatus           KYCCheckResult @default(PENDING)
  reviewNote          String?
  rejectionReason     String?
  submittedAt         DateTime       @default(now())
  reviewedAt          DateTime?
  lastCheckedAt       DateTime?
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_records")
}

model Listing {
  id          String        @id @default(cuid())
  title       String
  description String
  location    String
  region      String
  latitude    Float?
  longitude   Float?
  price       Decimal       @db.Decimal(12, 2)
  currency    String        @default("GBP")
  bedrooms    Int           @default(0)
  bathrooms   Int           @default(0)
  sizeSqm     Int           @default(0)
  type        PropertyType
  status      ListingStatus @default(DRAFT)
  verified    Boolean       @default(false)
  agentId     String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  agent       User           @relation(fields: [agentId], references: [id])
  photos      ListingPhoto[]
  enquiries   Enquiry[]
  savedBy     SavedListing[]
  escrows     EscrowTransaction[]
  documents   Document[]

  @@map("listings")
}

model ListingPhoto {
  id        String   @id @default(cuid())
  listingId String
  url       String
  publicId  String
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_photos")
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  savedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("saved_listings")
}

model Enquiry {
  id        String        @id @default(cuid())
  listingId String
  buyerId   String
  message   String
  phone     String?
  status    EnquiryStatus @default(SENT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  listing   Listing       @relation(fields: [listingId], references: [id])
  buyer     User          @relation(fields: [buyerId], references: [id])

  @@map("enquiries")
}

model EscrowTransaction {
  id                String             @id @default(cuid())
  listingId         String
  buyerId           String
  amountGBP         Decimal            @db.Decimal(12, 2)
  amountGMD         Decimal?           @db.Decimal(14, 2)
  platformFee       Decimal            @db.Decimal(10, 2)
  status            EscrowStatus       @default(INITIATED)
  fundingCurrency   String             @default("GBP")
  paymentProvider   PaymentProvider?
  paymentMethod     PaymentMethod?
  paymentStatus     PaymentStatus      @default(NOT_STARTED)
  stripePaymentId   String?
  providerPaymentId String?
  providerReference String?
  checkoutUrl       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  fundedAt          DateTime?
  refundedAt        DateTime?
  listing           Listing            @relation(fields: [listingId], references: [id])
  buyer             User               @relation(fields: [buyerId], references: [id])
  auditEvents       EscrowAuditEvent[]
  documents         Document[]

  @@map("escrow_transactions")
}

model EscrowAuditEvent {
  id          String            @id @default(cuid())
  escrowId    String
  event       String
  fromStatus  String?
  toStatus    String
  performedBy String?
  note        String?
  createdAt   DateTime          @default(now())
  escrow      EscrowTransaction @relation(fields: [escrowId], references: [id])

  @@map("escrow_audit_events")
}

model Document {
  id        String             @id @default(cuid())
  listingId String?
  escrowId  String?
  name      String
  s3Key     String
  s3Url     String
  type      String
  signedAt  DateTime?
  createdAt DateTime           @default(now())
  listing   Listing?           @relation(fields: [listingId], references: [id])
  escrow    EscrowTransaction? @relation(fields: [escrowId], references: [id])

  @@map("documents")
}
