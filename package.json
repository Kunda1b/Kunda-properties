{
  "name": "kunda-properties",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "dev:web": "turbo run dev --filter=@kunda/web",
    "dev:gateway": "turbo run dev --filter=@kunda/gateway",
    "dev:auth": "turbo run dev --filter=@kunda/auth",
    "dev:listings": "turbo run dev --filter=@kunda/listings",
    "dev:escrow": "turbo run dev --filter=@kunda/escrow",
    "dev:documents": "turbo run dev --filter=@kunda/documents",
    "dev:notifications": "turbo run dev --filter=@kunda/notifications",
    "dev:services": "turbo run dev --filter=@kunda/gateway --filter=@kunda/auth --filter=@kunda/listings --filter=@kunda/escrow --filter=@kunda/documents --filter=@kunda/notifications",
    "dev:backend": "turbo run dev --filter=@kunda/auth --filter=@kunda/listings",
    "dev:all": "turbo run dev --filter=@kunda/web --filter=@kunda/auth",
    "dev:mobile": "turbo run dev --filter=@kunda/mobile",
    "dev:admin": "turbo run dev --filter=@kunda/admin"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.6",
    "turbo": "^2.9.3",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.0"
}
