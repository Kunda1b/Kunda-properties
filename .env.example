# ── Node ──────────────────────────────────
NODE_ENV=development

# ── Database ──────────────────────────────
POSTGRES_USER=kunda
POSTGRES_PASSWORD=kunda_secret
POSTGRES_DB=kunda_db
DATABASE_URL=postgresql://kunda:kunda_secret@localhost:5432/kunda_db

# ── Redis ─────────────────────────────────
REDIS_URL=redis://:redis_secret@localhost:6379
REDIS_PASSWORD=redis_secret

# ── JWT (generate: openssl rand -base64 64)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# ── Stripe ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Cloudinary ────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud
CLOUDINARY_API_KEY=your_key
CLOUDINARY_API_SECRET=your_secret

# ── Smile Identity KYC ────────────────────
SMILE_IDENTITY_PARTNER_ID=your_partner_id
SMILE_IDENTITY_API_KEY=your_api_key
SMILE_IDENTITY_ENVIRONMENT=sandbox

# ── SendGrid ──────────────────────────────
SENDGRID_API_KEY=SG.xxx
FROM_EMAIL=noreply@kundaproperties.gm

# ── Twilio SMS ────────────────────────────
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=your_token
TWILIO_FROM_NUMBER=+1234567890

# ── Firebase Push ─────────────────────────
FIREBASE_PROJECT_ID=kunda-properties
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@kunda-properties.iam.gserviceaccount.com

# ── Mapbox ────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ── Document Encryption ───────────────────
DOCUMENT_ENCRYPTION_KEY=your_32_byte_hex

# ── URLs ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
